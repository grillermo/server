# Global Config
set daemon 30
set logfile /tmp/monit.log
set pidfile /tmp/monit.pid

# Web Interface
set httpd port 2812
    allow admin:changeme  # Remember to change this password

# --- BACKGROUND PROCESSES ---

check process kimai matching "kimai.*./serve"
    start program = "/bin/bash -c 'cd /Users/grillermo/c/kimai && nohup ./serve > output.log 2>&1 &'"
    stop program  = "/usr/bin/pkill -f 'kimai.*./serve'"
    if failed host 127.0.0.1 port 8001 protocol http for 2 cycles then restart

