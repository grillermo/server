# grillermo_com
:80 {
	root * /Users/grillermo/c/grillermo_com
	file_server
}

# Auto Email Classifier
:3000 {
	# 1. Serve static assets 
	handle /Users/grillermo/c/auto-email-classifier/public/assets/* {
		file_server
	}

	# 2. Proxy everything else to your service on port 3000
	handle {
		reverse_proxy localhost:3001 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	log {
		output file /Users/grillermo/c/auto-email-classifier/logs/caddy_access.log {
			roll_size 100mb # Rotate when a log reaches 100MB
			roll_keep 10 # Keep a maximum of 10 log files
			roll_keep_for 7d # Keep logs for exactly 7 days
		}
	}
}

# readitsoon
:4000 {
	# 1. Serve static assets 
	handle /public/* {
		root * /Users/grillermo/c/readitsoon
		file_server
	}

	# 2. Proxy to blue (4001) or green (4003) — first healthy slot wins
	handle {
		reverse_proxy localhost:4001 localhost:4003 {
			lb_policy first
			fail_duration 5s
			lb_try_duration 8s

			# active health checking
			health_uri /health
			health_interval 10s
			health_timeout 3s
			health_status 200
			health_body `"ok":true`

			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	log {
		output file /Users/grillermo/c/readitsoon/log/caddy_access.log {
			roll_size 100mb # Rotate when a log reaches 100MB
			roll_keep 10 # Keep a maximum of 10 log files
			roll_keep_for 7d # Keep logs for exactly 7 days
		}
	}
}

# yosubee
:3200 {
	handle /public/* {
		root * /Users/grillermo/c/yosubee
		file_server
	}

	# Proxy to blue (3201) and green (3202) — balance across both
	handle {
		reverse_proxy localhost:3201 localhost:3202 {
			lb_policy round_robin
			fail_duration 5s
			lb_try_duration 8s

			# active health checking
			health_uri /health
			health_interval 10s
			health_timeout 3s
			health_status 200
			health_body `"ok":true`

			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	log {
		output file /Users/grillermo/c/yosubee/log/caddy_access.log {
			roll_size 100mb # Rotate when a log reaches 100MB
			roll_keep 10 # Keep a maximum of 10 log files
			roll_keep_for 7d # Keep logs for exactly 7 days
		}
	}
}
